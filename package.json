{
  "name": "@bentonow/bento-node-sdk",
  "version": "1.0.9",
  "description": "🍱 Bento Node.JS SDK and tracking library",
  "author": "Backpack Internet",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist && tsc --emitDeclarationOnly",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "bun run build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/bentonow/bento-node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/bentonow/bento-node-sdk/issues"
  },
  "homepage": "https://bentonow.com",
  "devDependencies": {
    "@size-limit/preset-small-lib": "11.2.0",
    "@types/node": "22.13.4",
    "@typescript-eslint/eslint-plugin": "8.24.0",
    "@typescript-eslint/parser": "8.24.0",
    "bun-types": "1.2.2",
    "eslint": "9.39.4",
    "prettier": "3.5.1",
    "size-limit": "11.2.0",
    "typescript": "5.7.3"
  },
  "dependencies": {},
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "15 KB"
    }
  ]
}
